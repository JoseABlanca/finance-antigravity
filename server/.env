# Configuración de Servidor
PORT=3001

# Configuración de Base de Datos
DB_PATH=finance_app.db

# Configuración de Correo Electrónico (SMTP)
# Si estas variables están vacías o comentadas, el sistema usará Ethereal Email (Prueba)
# y generará un enlace de vista previa en la aplicación.

# Para usar Gmail, Outlook, etc., rellena lo siguiente:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tucorreo@gmail.com
# SMTP_PASS=tu_contraseña_de_aplicacion
